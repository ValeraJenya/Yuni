{
  "name": "yuni",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --dir apps/frontend dev",
    "dev:frontend": "pnpm --dir apps/frontend dev",
    "dev:backend": "pnpm --dir apps/backend dev",
    "build": "pnpm --dir apps/frontend build",
    "build:frontend": "pnpm --dir apps/frontend build",
    "build:backend": "pnpm --dir apps/backend build",
    "start": "pnpm --dir apps/frontend start",
    "start:backend": "pnpm --dir apps/backend start",
    "lint": "pnpm --dir apps/frontend lint",
    "lint:frontend": "pnpm --dir apps/frontend lint",
    "lint:backend": "pnpm --dir apps/backend lint",
    "typecheck:frontend": "pnpm --dir apps/frontend typecheck",
    "check:frontend": "pnpm --dir apps/frontend lint && pnpm --dir apps/frontend typecheck && pnpm --dir apps/frontend build",
    "check:backend": "corepack pnpm --dir apps/backend prisma:validate && corepack pnpm --dir apps/backend prisma:generate && pnpm --dir apps/backend build && pnpm --dir apps/backend lint",
    "check": "pnpm check:backend && pnpm check:frontend",
    "prisma:generate": "corepack pnpm --dir apps/backend prisma:generate",
    "prisma:validate": "corepack pnpm --dir apps/backend prisma:validate",
    "prisma:migrate:dev": "corepack pnpm --dir apps/backend prisma:migrate:dev",
    "prisma:migrate:deploy": "corepack pnpm --dir apps/backend prisma:migrate:deploy",
    "prisma:migrate:reset": "corepack pnpm --dir apps/backend prisma:migrate:reset"
  }
}
