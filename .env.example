# Скопируйте файл в локальный .env и замените значения на реальные.
# Не храните настоящие секреты в .env.example.

NEXT_PUBLIC_APP_NAME=Yuni

PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yuni
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Используйте длинные случайные значения в локальном .env.
JWT_ACCESS_SECRET=replace-with-local-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-local-refresh-secret-at-least-32-chars
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
